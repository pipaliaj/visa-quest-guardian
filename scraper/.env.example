# Webhook endpoint (your published Lovable app)
WEBHOOK_URL=https://notify.jaypipalia.com/api/public/slots

# Scraper key generated in Dashboard -> Admin (starts with ssk_)
SCRAPER_KEY=ssk_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tuning
POLL_INTERVAL_SEC=90
JITTER_SEC=30
HEARTBEAT_SEC=300
HEADLESS=true
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36