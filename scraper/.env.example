# Webhook endpoint (your published Lovable app)
WEBHOOK_URL=https://notify.jaypipalia.com/api/public/slots

# Scraper key generated in Dashboard -> Admin (starts with ssk_)
SCRAPER_KEY=ssk_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tuning
POLL_INTERVAL_SEC=90
JITTER_SEC=30
HEARTBEAT_SEC=300
HEADLESS=true
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# --- Email OTP retrieval (VFS sends a 6-digit OTP to the login email) ---
# IMAP server for the inbox that receives VFS OTP emails.
# Gmail: imap.gmail.com:993 with an App Password (NOT your normal password).
# IMAP_USER usually equals the VFS login email. If you use a forwarding mailbox
# (e.g. otp@yourdomain.com), point IMAP at that mailbox instead.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASS=app_password_here
IMAP_TLS=true
# How long to poll the inbox for an OTP after submitting login (seconds)
OTP_WAIT_SEC=120
# Optional: only accept OTP emails whose From matches this substring (case-insensitive)
OTP_FROM_FILTER=vfsglobal
# Optional: only accept OTP emails whose subject matches this substring (case-insensitive)
OTP_SUBJECT_FILTER=